<?xml version="1.0" ?>
<!--
  舵輪驅動(tricycle / reach-truck)叉車 — 方塊車身版。
  構型:一顆「可轉向 + 可驅動」的舵輪(後,-X 端)+ 兩顆從動承載輪(前,+X 叉子端)
        + 可升降叉子(prismatic)。純 gz 原生 plugin,不需 ROS 2。

  純 Gazebo 驅動(範例):
    gz topic -t /forklift/traction -m gz.msgs.Double -p 'data: 6.0'   # 舵輪轉速(rad/s)
    gz topic -t /forklift/steer    -m gz.msgs.Double -p 'data: 0.4'   # 舵角(rad)
    gz topic -t /forklift/fork     -m gz.msgs.Double -p 'data: 0.3'   # 叉子高度(m)

  座標:ground 在 z=0;輪半徑 0.15,輪心 z=0.15。慣性以 box/cylinder 公式算,過三角不等式。
  PID 與摩擦為初值,待實機(CI/gz sim)調整。
-->
<sdf version="1.10">
  <model name="forklift">

    <!-- ===== 車身 ===== -->
    <link name="base_link">
      <pose>0 0 0.45 0 0 0</pose>
      <inertial>
        <mass>80</mass>
        <inertia>
          <ixx>4.333</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>10.667</iyy><iyz>0</iyz><izz>12.867</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><box><size>1.2 0.7 0.4</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>1.2 0.7 0.4</size></box></geometry>
        <material><ambient>0.9 0.6 0.1 1</ambient><diffuse>0.9 0.6 0.1 1</diffuse></material>
      </visual>
      <!-- 桅杆視覺(叉子端立柱,純好看)-->
      <visual name="mast">
        <pose>0.6 0 0.25 0 0 0</pose>
        <geometry><box><size>0.1 0.6 0.9</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
    </link>

    <!-- ===== 舵輪轉向樞紐(steer_link)===== -->
    <link name="steer_link">
      <pose>-0.5 0 0.15 0 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.0048</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0048</iyy><iyz>0</iyz><izz>0.0048</izz></inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>0.12 0.12 0.12</size></box></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- ===== 舵輪(驅動輪)===== -->
    <link name="traction_wheel">
      <pose>-0.5 0 0.15 1.5708 0 0</pose>
      <inertial>
        <mass>5</mass>
        <inertia><ixx>0.0308</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0308</iyy><iyz>0</iyz><izz>0.05625</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
    </link>

    <!-- ===== 兩顆從動承載輪(叉子端)===== -->
    <link name="left_load_wheel">
      <pose>0.5 0.3 0.15 1.5708 0 0</pose>
      <inertial>
        <mass>4</mass>
        <inertia><ixx>0.02463</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.02463</iyy><iyz>0</iyz><izz>0.045</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
    </link>
    <link name="right_load_wheel">
      <pose>0.5 -0.3 0.15 1.5708 0 0</pose>
      <inertial>
        <mass>4</mass>
        <inertia><ixx>0.02463</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.02463</iyy><iyz>0</iyz><izz>0.045</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.15</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
    </link>

    <!-- ===== 叉子(可升降)===== -->
    <link name="fork_carriage">
      <pose>1.05 0 0.1 0 0 0</pose>
      <inertial>
        <mass>12</mass>
        <inertia><ixx>0.2564</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1.0064</iyy><iyz>0</iyz><izz>1.25</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><box><size>1.0 0.5 0.08</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>1.0 0.5 0.08</size></box></geometry>
        <material><ambient>0.7 0.7 0.1 1</ambient><diffuse>0.7 0.7 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- ===== 關節 ===== -->
    <!-- 轉向:base → steer_link,繞 Z -->
    <joint name="steering_joint" type="revolute">
      <parent>base_link</parent><child>steer_link</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-0.7</lower><upper>0.7</upper><effort>200</effort><velocity>2</velocity></limit></axis>
    </joint>
    <!-- 驅動:steer_link → 舵輪,繞 Y(連續)-->
    <joint name="traction_joint" type="revolute">
      <parent>steer_link</parent><child>traction_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper><effort>200</effort><velocity>50</velocity></limit></axis>
    </joint>
    <!-- 從動輪(被動,繞 Y 自由滾)-->
    <joint name="left_load_joint" type="revolute">
      <parent>base_link</parent><child>left_load_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper><effort>0</effort><velocity>50</velocity></limit></axis>
    </joint>
    <joint name="right_load_joint" type="revolute">
      <parent>base_link</parent><child>right_load_wheel</child>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper><effort>0</effort><velocity>50</velocity></limit></axis>
    </joint>
    <!-- 叉子升降:base → fork_carriage,沿 Z(prismatic)-->
    <joint name="fork_joint" type="prismatic">
      <parent>base_link</parent><child>fork_carriage</child>
      <axis><xyz>0 0 1</xyz><limit><lower>0</lower><upper>0.5</upper><effort>3000</effort><velocity>0.3</velocity></limit></axis>
    </joint>

    <!-- ===== gz 原生控制 plugin(純 Gazebo,不需 ROS 2)===== -->
    <!-- 舵輪驅動:速度命令(gz.msgs.Double, rad/s)-->
    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>traction_joint</joint_name>
      <topic>/forklift/traction</topic>
    </plugin>
    <!-- 轉向:位置命令(gz.msgs.Double, rad)。PID 待調 -->
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>steering_joint</joint_name>
      <topic>/forklift/steer</topic>
      <p_gain>30</p_gain><i_gain>0.5</i_gain><d_gain>3</d_gain>
    </plugin>
    <!-- 叉子升降:位置命令(gz.msgs.Double, m)。要頂重力,p_gain 較大,待調 -->
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>fork_joint</joint_name>
      <topic>/forklift/fork</topic>
      <p_gain>8000</p_gain><i_gain>20</i_gain><d_gain>200</d_gain>
    </plugin>
    <!-- 發布車身位姿,供「它有沒有動」的測試讀取 -->
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_model_pose>true</publish_model_pose>
      <publish_link_pose>false</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <update_frequency>20</update_frequency>
    </plugin>

  </model>
</sdf>
