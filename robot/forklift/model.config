<?xml version="1.0" ?>
<model>
  <name>forklift</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <author>
    <name>robot-notes</name>
  </author>
  <description>
    舵輪驅動(tricycle / reach-truck)叉車,方塊車身版。一顆可轉向+驅動的舵輪(後)
    + 兩顆從動承載輪(前,叉子端)+ 可升降叉子。用 gz 原生 plugin,純 Gazebo 即可
    驅動/轉向/升叉,不需 ROS 2。先求會動,外觀之後可換 Fuel Forklift mesh。
  </description>
</model>
